{
  "productName": "view.md",
  "version": "1.0.0",
  "identifier": "com.viewmd.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "view.md",
        "width": 1080,
        "height": 760,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown File",
        "role": "Viewer",
        "description": "Markdown Document"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
